From 48834ac80124a27a300393e8aa7b6ff653ce5411 Mon Sep 17 00:00:00 2001
From: effectsbot <eff3ctsb0t@gmail.com>
Date: Sun, 1 Mar 2026 16:06:12 +0100
Subject: [PATCH 16/25] winex11: Add Xwayland check

Signed-off-by: effectsbot <eff3ctsb0t@gmail.com>
---
 dlls/winex11.drv/x11drv.h      | 1 +
 dlls/winex11.drv/x11drv_main.c | 3 +++
 2 files changed, 4 insertions(+)

diff --git a/dlls/winex11.drv/x11drv.h b/dlls/winex11.drv/x11drv.h
index 109e463..c83b0ba 100644
--- a/dlls/winex11.drv/x11drv.h
+++ b/dlls/winex11.drv/x11drv.h
@@ -449,6 +449,7 @@ extern BOOL grab_fullscreen;
 extern int keyboard_layout;
 extern BOOL keyboard_scancode_detect;
 extern BOOL usexcomposite;
+extern BOOL xwayland;
 extern BOOL use_xfixes;
 extern BOOL managed_mode;
 extern BOOL private_color_map;
diff --git a/dlls/winex11.drv/x11drv_main.c b/dlls/winex11.drv/x11drv_main.c
index fddea38..881cd97 100644
--- a/dlls/winex11.drv/x11drv_main.c
+++ b/dlls/winex11.drv/x11drv_main.c
@@ -69,6 +69,7 @@ Window root_window;
 BOOL usexvidmode = TRUE;
 BOOL usexrandr = TRUE;
 BOOL usexcomposite = TRUE;
+BOOL xwayland = FALSE;
 BOOL use_xfixes = FALSE;
 BOOL use_take_focus = TRUE;
 BOOL use_primary_selection = FALSE;
@@ -803,6 +804,8 @@ static NTSTATUS x11drv_init( void *arg )
                    DisplayHeight( display, default_visual.screen ));
     X11DRV_Settings_Init();
 
+    xwayland = !strcmp(getenv("XDG_SESSION_TYPE"), "wayland");
+
     /* initialize XVidMode */
     X11DRV_XF86VM_Init();
     /* initialize XRandR */
-- 
